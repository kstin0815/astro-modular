---
import { siteConfig } from '@/config';
if (!siteConfig.postOptions.comments.enabled) {
  return null;
}
const CUSDIS_APP_ID = "70ca15eb-b428-4fbe-b4d1-79f46be948b9";
---

<style>
  #cusdis_thread iframe {
    width: 100% !important;
    border: none !important;
    display: block;
  }
</style>

<div class="cusdis-comments-container" style="margin-top: 2rem; max-width: 100%; border-top: 1px solid var(--border-color, #e5e7eb); padding-top: 2rem;">
  <div
    id="cusdis_thread"
    data-host="https://cusdis.com"
    data-app-id={CUSDIS_APP_ID}
  ></div>
</div>

<script is:inline>
  (function () {
    var currentIframe = null;

    // Cusdis 每次回報高度就調整 iframe（會長也會縮）
    function setHeight(h) {
      var n = parseInt(h, 10);
      if (isNaN(n)) return;
      if (!currentIframe) {
        currentIframe = document.querySelector('#cusdis_thread iframe');
      }
      if (currentIframe) {
        currentIframe.style.height = (n + 24) + 'px';
      }
    }

    // 持續監聽 Cusdis 的訊息：載入、留言、送出都會觸發
    window.addEventListener('message', function (e) {
      if (e && e.data && e.data.from === 'cusdis' && e.data.event === 'resize') {
        setHeight(e.data.data);
      }
    });

    function watchForIframe() {
      var thread = document.getElementById('cusdis_thread');
      if (!thread) return;
      var observer = new MutationObserver(function () {
        var iframe = document.querySelector('#cusdis_thread iframe');
        if (iframe) {
          currentIframe = iframe;
          iframe.setAttribute('scrolling', 'no');
          iframe.style.width = '100%';
          // 不寫死高度，交給上面的 message 監聽動態調整
          observer.disconnect();
        }
      });
      observer.observe(thread, { childList: true, subtree: true });
    }

    function renderCusdis() {
      var el = document.getElementById('cusdis_thread');
      if (!el) return;
      currentIframe = null;
      el.setAttribute('data-page-id', location.pathname);
      el.setAttribute('data-page-url', location.href);
      el.setAttribute('data-page-title', document.title);
      watchForIframe();
      if (window.CUSDIS) {
        window.CUSDIS.initial();
      } else {
        var s = document.createElement('script');
        s.async = true;
        s.defer = true;
        s.src = 'https://cusdis.com/js/cusdis.es.js';
        document.body.appendChild(s);
      }
    }

    renderCusdis();

    function hookSwup() {
      if (window.swup && window.swup.hooks) {
        window.swup.hooks.on('page:view', renderCusdis);
        return true;
      }
      return false;
    }
    if (!hookSwup()) {
      document.addEventListener('swup:enable', hookSwup);
    }
  })();
</script>
